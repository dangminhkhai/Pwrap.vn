{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Dịch Vụ Gốc",
    "description": "Thông tin chung của các dịch vụ ô tô"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "richText": {
      "type": "blocks"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "videoUrl": {
      "type": "string"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDesc": {
      "type": "text"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
