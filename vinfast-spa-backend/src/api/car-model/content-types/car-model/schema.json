{
  "kind": "collectionType",
  "collectionName": "car_models",
  "info": {
    "singularName": "car-model",
    "pluralName": "car-models",
    "displayName": "Dòng Xe",
    "description": "Danh sách các dòng xe VinFast"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "isHot": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "longDescription": {
      "type": "richtext"
    },
    "showLongDescription": {
      "type": "boolean",
      "default": true
    },
    "banner": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
